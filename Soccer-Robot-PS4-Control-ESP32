#include <PS4Controller.h>

// 1. Pin Definitions for Motor Driver (L298N/BTS7960)
int enA = 25; int in1 = 26; int in2 = 27;
int enB = 33; int in3 = 14; int in4 = 32; 

// 2. PWM Settings for ESP32 LEDC
const int freq = 5000;
const int ledChannelA = 0;
const int ledChannelB = 1;
const int resolution = 8;
int currentSpeed = 160; // Initial speed (Medium)

void setup() {
  pinMode(in1, OUTPUT); pinMode(in2, OUTPUT);
  pinMode(in3, OUTPUT); pinMode(in4, OUTPUT);
  
  // Configure PWM Channels
  ledcSetup(ledChannelA, freq, resolution);
  ledcSetup(ledChannelB, freq, resolution);
  
  // Attach Pins to PWM Channels
  ledcAttachPin(enA, ledChannelA);
  ledcAttachPin(enB, ledChannelB);
  
  Serial.begin(115200);
  
  // Initialize PS4 Controller with stored MAC Address
  if (!PS4.begin("ec:e3:34:19:b2:3c")) {
    Serial.println("Bluetooth Stack Error!");
  }
  
  Serial.println("System Ready! Control the Soccer Robot with D-Pad Arrows.");
}

void loop() {
  if (PS4.isConnected()) {
    
    // Speed Control System (Gears)
    if (PS4.Square())   { currentSpeed = 150; Serial.println("Speed: Low"); }
    if (PS4.Cross())    { currentSpeed = 190; Serial.println("Speed: Medium"); }
    if (PS4.Circle())   { currentSpeed = 230; Serial.println("Speed: High"); }
    if (PS4.Triangle()) { currentSpeed = 255; Serial.println("Speed: Max"); }

    // Movement Control Logic
    if (PS4.Up()) {
      Serial.println("Moving Forward");
      move(currentSpeed, 0, 1, 0, 1); 
    } 
    else if (PS4.Down()) {
      Serial.println("Moving Backward");
      move(currentSpeed, 1, 0, 1, 0); 
    } 
    else if (PS4.Right()) {
      Serial.println("Turning Right");
      move(currentSpeed, 1, 0, 0, 1); // Center Pivot Turn Right
    } 
    else if (PS4.Left()) {
      Serial.println("Turning Left");
      move(currentSpeed, 0, 1, 1, 0); // Center Pivot Turn Left
    } 
    else {
      // Stop when no buttons are pressed
      move(0, 0, 0, 0, 0); 
    }
  }
}

// Unified Movement Function
void move(int speed, int i1, int i2, int i3, int i4) {
  ledcWrite(ledChannelA, speed);
  ledcWrite(ledChannelB, speed);
  
  digitalWrite(in1, i1);
  digitalWrite(in2, i2);
  digitalWrite(in3, i3);
  digitalWrite(in4, i4);
}
